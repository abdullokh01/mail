# ─────────────────────────────────────────────────────────────
# B-Point Executive Decision Center — environment template
# Copy to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# --- Database (Supabase Postgres) ---
# DATABASE_URL: runtime connection.
#   Local/migrations: direct connection, port 5432.
#   Vercel/serverless: Transaction Pooler, port 6543, add ?pgbouncer=true
# DIRECT_URL: always the direct connection (port 5432) — used by Prisma migrate.
# URL-encode special chars in the password ($ -> %24, ! -> %21, @ -> %40 ...).
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- NextAuth / Auth.js ---
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-generated-secret"
AUTH_SECRET="your-generated-secret"

# --- Google OAuth (Gmail) ---
# Google Cloud Console > Credentials. Enable Gmail API.
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# --- Gemini (Google AI) ---
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash"

# --- Supabase (client, optional) ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- App ---
EMAIL_SYNC_LIMIT="100"
# Pause (ms) between AI calls. Set ~4000 for Gemini free tier (~15 req/min). 0 = no pause.
AI_THROTTLE_MS="0"
AI_MAX_RETRIES="3"
